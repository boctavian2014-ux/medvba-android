# ===========================================
# MEDVBA – variabile pentru build Google Play
# ===========================================
# Copiază acest fișier ca .env și completează valorile.
# NU comite niciodată .env în git (e în .gitignore). Secretele rămân doar local / EAS / Railway.
# Pentru EAS Build: folosești EAS Secrets (Dashboard sau eas env:create).

# ---------- Supabase (login, progres utilizator) ----------
EXPO_PUBLIC_SUPABASE_URL=https://XXXXXXXX.supabase.co
EXPO_PUBLIC_SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.XXXXX

# ---------- RevenueCat (abonamente – Google Play / App Store) ----------
# Copiază EXACT ce îți arată RevenueCat pentru fiecare aplicație.
# Android: RevenueCat → Project → API Keys → aplicația ANDROID (Google Play) → Public key (de obicei goog_...)
# iOS:     RevenueCat → Project → API Keys → aplicația iOS (App Store)     → Public key (de obicei appl_...)
EXPO_PUBLIC_REVENUECAT_API_KEY_ANDROID=
EXPO_PUBLIC_REVENUECAT_API_KEY_IOS=

# Paywall activ: true = limită zilnică + upgrade, false = totul gratuit
EXPO_PUBLIC_PAYWALL_ENABLED=true

# ---------- Backend API (tRPC server for AI tutor) ----------
# Your Railway backend deployment URL
EXPO_PUBLIC_RORK_API_BASE_URL=https://your-backend.up.railway.app

# ---------- Opțional: Sentry (erori / crash reporting) ----------
# EXPO_PUBLIC_SENTRY_DSN=https://xxx@xxx.ingest.sentry.io/xxx

# ---------- Social Authentication (Google, Facebook, Apple) ----------
# Google Sign-In: Create OAuth 2.0 credentials at https://console.cloud.google.com/apis/credentials
EXPO_PUBLIC_GOOGLE_IOS_CLIENT_ID=your_ios_client_id.apps.googleusercontent.com
EXPO_PUBLIC_GOOGLE_ANDROID_CLIENT_ID=your_android_client_id.apps.googleusercontent.com
EXPO_PUBLIC_GOOGLE_WEB_CLIENT_ID=your_web_client_id.apps.googleusercontent.com

# Facebook Login: Create an app at https://developers.facebook.com
EXPO_PUBLIC_FACEBOOK_APP_ID=your_facebook_app_id

# Apple Sign-In: Configure in Xcode under Signing & Capabilities → Sign In with Apple
EXPO_PUBLIC_APPLE_CLIENT_ID=com.your.bundle.id

# ---------- AI Tutor Provider ----------
# Supported providers: openai, rork
EXPO_PUBLIC_AI_PROVIDER=openai

# OpenAI API Key (for openai provider)
EXPO_PUBLIC_AI_API_KEY=sk-your-openai-api-key

# Optional: Custom OpenAI-compatible base URL (for proxies like together.ai, openrouter)
EXPO_PUBLIC_AI_BASE_URL=https://api.openai.com/v1

# Optional: Model to use (default: gpt-4o-mini)
EXPO_PUBLIC_AI_MODEL=gpt-4o-mini

# Rork API (for rork provider) - alternative to OpenAI
# EXPO_PUBLIC_RORK_API_BASE_URL=https://your-rork-api.com

# Password Reset Redirect URI (deep link for password reset)
EXPO_PUBLIC_PASSWORD_RESET_REDIRECT_URI=medvba://reset-password

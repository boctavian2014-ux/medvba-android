# ===========================================
# MEDVBA – variabile pentru build Google Play
# ===========================================
# Copiază acest fișier ca .env și completează valorile.
# NU comite niciodată .env în git (e în .gitignore). Secretele rămân doar local / EAS / Railway.
# Pentru EAS Build: folosești EAS Secrets (Dashboard sau eas env:create).
#
# Expo încarcă în app.config.ts doar cheile EXPO_PUBLIC_* de mai jos (plus procesul de build
# poate injecta EXPO_PUBLIC_SENTRY_DSN). Nu pune niciodată chei OpenAI sau service_role
# în EXPO_PUBLIC_* — ele apar în bundle-ul clientului.
# Nu defini EXPO_PUBLIC_AI_API_KEY: backend-ul folosește doar AI_API_KEY / OPENAI_API_KEY (vezi secțiunea backend).

# ---------- Supabase (client — login, progres utilizator) ----------
EXPO_PUBLIC_SUPABASE_URL=https://XXXXXXXX.supabase.co
EXPO_PUBLIC_SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.XXXXX

# ---------- RevenueCat (abonamente – Google Play / App Store) ----------
# Copiază EXACT ce îți arată RevenueCat pentru fiecare aplicație.
# Android: RevenueCat → Project → API Keys → aplicația ANDROID (Google Play) → Public key (de obicei goog_...)
# iOS:     RevenueCat → Project → API Keys → aplicația iOS (App Store)     → Public key (de obicei appl_...)
EXPO_PUBLIC_REVENUECAT_API_KEY_ANDROID=
EXPO_PUBLIC_REVENUECAT_API_KEY_IOS=

# Paywall activ: true = limită zilnică + upgrade, false = totul gratuit
EXPO_PUBLIC_PAYWALL_ENABLED=true

# ---------- Backend API (client — Bază URL Hono + tRPC pe Railway) ----------
# Folosit de lib/trpc.ts. În producție trebuie să fie HTTPS.
EXPO_PUBLIC_API_BASE_URL=https://your-backend.up.railway.app

# ---------- Opțional: Sentry (erori / crash reporting în app) ----------
# NU e listat în app.config extra; dacă e setat la EAS build, e disponibil ca EXPO_PUBLIC_*.
# EXPO_PUBLIC_SENTRY_DSN=https://xxx@xxx.ingest.sentry.io/xxx

# ---------- Social Authentication (Google, Facebook, Apple) ----------
# Google Sign-In: https://console.cloud.google.com/apis/credentials
#
# EXPO_PUBLIC_GOOGLE_WEB_CLIENT_ID = OAuth client type "Web application" (used for idToken / Supabase).
# EXPO_PUBLIC_GOOGLE_IOS_CLIENT_ID = iOS client (same Cloud project).
# EXPO_PUBLIC_GOOGLE_ANDROID_CLIENT_ID = optional reference only; the native SDK does not use it in configure().
#
# Android: create a separate OAuth client type "Android" with package com.devaieood.medvba + SHA-1:
#   - EAS/internal APK: SHA-1 from the keystore EAS uses (eas credentials / expo.dev).
#   - Play Store install: add SHA-1 from Play Console → Release → App integrity → App signing key certificate
#     (Google re-signs the app; upload-key SHA-1 alone is often NOT enough for store builds).
EXPO_PUBLIC_GOOGLE_IOS_CLIENT_ID=your_ios_client_id.apps.googleusercontent.com
EXPO_PUBLIC_GOOGLE_ANDROID_CLIENT_ID=your_android_client_id.apps.googleusercontent.com
EXPO_PUBLIC_GOOGLE_WEB_CLIENT_ID=your_web_client_id.apps.googleusercontent.com

# Facebook Login: Create an app at https://developers.facebook.com
# Client Token: Meta Developer Console → App → Settings → Advanced → Client token (required by react-native-fbsdk-next Expo plugin + native SDK)
EXPO_PUBLIC_FACEBOOK_APP_ID=your_facebook_app_id
EXPO_PUBLIC_FACEBOOK_CLIENT_TOKEN=your_facebook_client_token

# Apple Sign-In (doar iOS, MEDVBA)
# Services ID (claim `sub` la generarea JWT pentru Supabase → Apple → Secret key): com.devaieood.medvba.auth
# Bundle Xcode: com.devaieood.medvba. În Supabase → Apple → „Client IDs” trebuie să apară valoarea din claim-ul `aud`
# al tokenului de la Apple (de obicei bundle-ul). Dacă e nevoie, adaugă ambele separate prin virgulă:
# com.devaieood.medvba,com.devaieood.medvba.auth
EXPO_PUBLIC_APPLE_CLIENT_ID=com.devaieood.medvba.auth

# Password Reset Redirect URI (deep link for password reset; trebuie aliniat cu Supabase Auth URL config)
EXPO_PUBLIC_PASSWORD_RESET_REDIRECT_URI=medvba://reset-password

# ---------- Backend local (Hono + tRPC) — NU în EAS, NU EXPO_PUBLIC pentru secrete ----------
# Doar dacă rulezi backend-ul local (ex. tsx backend/server.ts). Aceleași nume ca pe Railway.
# Tutor AI folosește lib/ai-provider.ts din backend (backend/trpc/tutor.ts) — cheia OpenAI NU
# există în client; setezi una dintre variabilele de mai jos pe server (Railway sau aici).
# Dacă ai EXPO_PUBLIC_AI_API_KEY în .env, șterge-o și folosește doar AI_API_KEY sau OPENAI_API_KEY aici.
#
# SUPABASE_URL=https://XXXXXXXX.supabase.co
# SUPABASE_SERVICE_ROLE_KEY=eyJ...service_role...
# AI_API_KEY=sk-...                    # recomandat (sau OPENAI_API_KEY)
# OPENAI_API_KEY=sk-...
# AI_PROVIDER=openai
# AI_BASE_URL=https://api.openai.com/v1
# AI_MODEL=gpt-4o-mini
# CORS_ALLOWED_ORIGINS=https://app.tudomeniu.com

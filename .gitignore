# Learn more https://docs.github.com/en/get-started/getting-started-with-git/ignoring-files

# dependencies
node_modules/
# package-lock.json is required for EAS Build (npm ci). bun.lock stays local / optional; .easignore excludes bun.lock on EAS.

# Expo
.expo/
dist/
web-build/
expo-env.d.ts

# Native (iOS generated locally / CI; Android is versioned for bare workflow)
ios/
*.orig.*
*.jks
*.p8
*.p12
*.key
*.mobileprovision

# Metro
.metro-health-check*

# debug
npm-debug.*
yarn-debug.*
yarn-error.*

# macOS
.DS_Store
*.pem

# local env files and secrets (never commit)
.env
.env*.local
.env.production
.env.*.local

# typescript
*.tsbuildinfo
.vercel

.rork

rork-eslint.config.js